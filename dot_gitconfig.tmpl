[user]
	name = {{ .git.name }}
	email = {{ .git.email }}
	{{- if .git.signingkey }}
	signingkey = {{ .git.signingkey }}
	{{- end }}
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[commit]
	gpgsign = {{ .git.signingkey | ne "" }}
[merge]
	ff = only
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[submodule]
	recurse = true
