{{- if eq .chezmoi.os "linux" }}
if test -f /usr/share/cachyos-fish-config/cachyos-config.fish
  source /usr/share/cachyos-fish-config/cachyos-config.fish
end

if test -f home/linuxbrew/.linuxbrew/bin/brew
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv fish)"
end
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
if test -x /opt/homebrew/bin/brew
  eval "$(/opt/homebrew/bin/brew shellenv)"
end
{{- end }}

fish_add_path "$HOME/.cargo/bin"
fish_add_path "$HOME/go/bin"
fish_add_path "$HOME/.local/bin"

if functions -q load_nvm
  load_nvm > /dev/stderr
end

{{- if eq .chezmoi.os "darwin" }}
# opencode
fish_add_path "$HOME/.opencode/bin"

# aistor
fish_add_path "$HOME/aistor-binaries"
{{- end }}

if command -q zoxide
  zoxide init fish | source
end
# overwrite greeting
# potentially disabling fastfetch
#function fish_greeting
#    # smth smth
#end

if command -q thefuck
  thefuck --alias | source
end

if command -q lsd
  alias ls='lsd'
{{- if eq .chezmoi.os "linux" }}
else if command -q ls
  alias ls='ls --color=auto'
{{- end }}
end

{{- if eq .chezmoi.os "linux" }}
if command -q grep
  alias grep='grep --color=auto'
end
{{- end }}

{{- if eq .chezmoi.os "linux" }}
if set -q XDG_RUNTIME_DIR
  set -Ux SSH_AUTH_SOCK $XDG_RUNTIME_DIR/ssh-agent.socket
end
{{- end }}

# bun
set --export BUN_INSTALL "$HOME/.bun"
if not string match -q -- $BUN_INSTALL/bin $PATH
  set --export PATH $BUN_INSTALL/bin $PATH
end

# pnpm
{{- if eq .chezmoi.os "darwin" }}
set -gx PNPM_HOME "$HOME/Library/pnpm"
{{- else }}
set -gx PNPM_HOME "$HOME/.local/share/pnpm"
{{- end }}
for pnpm_path in "$PNPM_HOME" "$PNPM_HOME/bin"
  if test -d "$pnpm_path"; and not contains -- "$pnpm_path" $PATH
    set -gx PATH "$pnpm_path" $PATH
  end
end
# pnpm end

set -gx EDITOR zed
set -gx VISUAL zed

if status is-interactive
  atuin init fish | source
end
