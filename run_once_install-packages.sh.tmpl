#!/bin/sh
set -eu

source_dir="{{ .chezmoi.sourceDir }}"

case "$(uname -s)" in
Darwin)
  os="macos"
  ;;
Linux)
  os="linux"
  ;;
*)
  echo "Unsupported OS: $(uname -s)" >&2
  exit 1
  ;;
esac

case "$(uname -m)" in
arm64 | aarch64)
  arch="arm64"
  ;;
x86_64 | amd64)
  arch="x86_64"
  ;;
*)
  echo "Unsupported architecture: $(uname -m)" >&2
  exit 1
  ;;
esac

cd "$source_dir/installer"

binary="bin/dotsetup-$os-$arch"

if [ ! -x "$binary" ]; then
  echo "Missing dotsetup binary: $binary" >&2
  exit 1
fi

if [ -z "${CI:-}" ]; then
  "$binary" bootstrap
fi

exec "$binary" install
