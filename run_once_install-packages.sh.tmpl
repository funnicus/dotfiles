#!/usr/bin/env bash
set -euo pipefail

if command -v pacman >/dev/null 2>&1; then
    command -v fish >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm fish
    command -v nvim >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm neovim
    command -v zoxide >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm zoxide
    command -v thefuck >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm thefuck
    command -v bw >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm bitwarden-cli
    command -v curl >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm curl
elif command -v brew >/dev/null 2>&1; then
    command -v fish >/dev/null 2>&1 || brew install fish
    command -v nvim >/dev/null 2>&1 || brew install neovim
    command -v zoxide >/dev/null 2>&1 || brew install zoxide
    command -v thefuck >/dev/null 2>&1 || brew install thefuck
    command -v bw >/dev/null 2>&1 || brew install bitwarden-cli
    command -v curl >/dev/null 2>&1 || brew install curl
fi

if ! command -v bun >/dev/null 2>&1; then
    curl -fsSL https://bun.sh/install | bash
fi

if ! command -v pnpm >/dev/null 2>&1; then
    curl -fsSL https://get.pnpm.io/install.sh | sh -
fi
